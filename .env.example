# ── Server ─────────────────────────────────────────────────────────────────────
PORT=8080
APP_VERSION=1.0.0

# ── Secrets (generate unique values per deployment) ──────────────────────────
AES_SECRET_KEY=
HMAC_SECRET_SALT=
# Must match LICENSE_SERVER_SECRET on the Discord bot.
# Use a strong random value; do not expose :8081 to the public internet without a firewall.
ADMIN_PASS=

# ── License keys ───────────────────────────────────────────────────────────────
# Prefix for auto-generated keys (e.g. SLYNX → SLYNX-A1B2-C3D4)
LICENSE_KEY_PREFIX=

# Legacy license rows with empty product_id in SQLite (maps to products/<id>/payload.ahk)
DEFAULT_PRODUCT_ID=recoil

# ── Optional ───────────────────────────────────────────────────────────────────
# Discord webhook for admin / security logs
DISCORD_WEBHOOK=

# Fallback if catalog.seed.json is missing on deploy:
# LICENSE_PRODUCT_IDS=recoil,other-macro
