# Secrets — never bake into Docker image layers
.env
private.pem
*.pem

# Runtime data — mounted as volumes at runtime
app_db/
db/
*.db
*.db-shm
*.db-wal

# Build artifacts and binaries
build/
main
server
server_release
*.exe
# ...except the auto-update client binary, which is baked into the image
!seed/client.exe

# macOS junk
.DS_Store
